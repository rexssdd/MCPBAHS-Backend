# Git
.git
.gitignore
.gitattributes

# Local environment — NEVER bake secrets into the image
.env
.env.local
.env.*.local

# Dev tooling
node_modules
npm-debug.log
yarn-error.log

# Tests & CI
tests
phpunit.xml
.phpunit.result.cache

# Editor / OS
.editorconfig
.idea
.vscode
*.DS_Store
Thumbs.db

# Docs
README.md
CHANGELOG.md

# Bootstrap caches — generated at container startup with live env vars
bootstrap/cache/config.php
bootstrap/cache/routes-v7.php
bootstrap/cache/services.php
bootstrap/cache/events.php
bootstrap/cache/packages.php

# Storage runtime files — generated at runtime
storage/logs/*.log
storage/framework/cache/data
storage/framework/sessions
storage/framework/views
# Vendor — Dockerfile runs `composer install` fresh; never ship local vendor
vendor

# Supabase CLI local cache — contains project ref / pooler URL, never ship
supabase/.temp
