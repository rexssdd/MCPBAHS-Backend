# ============================================================
# Production Environment Variables — Railway Deployment
# ============================================================
# Set ALL of these in:  Railway dashboard → your service → Variables
# NEVER commit real secrets to Git.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=HighSchoolManagementSystem
APP_ENV=production
# Generate with: php artisan key:generate --show
APP_KEY=base64:REPLACE_WITH_OUTPUT_OF_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://YOUR_BACKEND_DOMAIN.railway.app

# ── Database ──────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you link a Postgres plugin.
# Set DB_URL to that variable so Laravel parses it directly.
DB_CONNECTION=pgsql
DB_URL=${DATABASE_URL}
# Railway also exposes: PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD
# These are NOT needed when DB_URL is set — Laravel uses DB_URL first.

# Supabase users: use connection pooler URL (port 6543) and set sslmode=require
# DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DB_SSLMODE=require

# ── Logging ───────────────────────────────────────────────────
# stderr routes logs to Railway's log aggregator (visible in the Logs tab)
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ── Session & Cache ───────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
# SPA on a different domain (e.g. Vercel frontend + Railway backend) requires
# SameSite=None so the browser sends the session cookie on cross-site requests.
# Must be paired with SESSION_SECURE_COOKIE=true (None requires Secure).
SESSION_SAME_SITE=none
CACHE_STORE=database

# ── Queue ─────────────────────────────────────────────────────
QUEUE_CONNECTION=database
# For a dedicated worker, add a second Railway service running:
#   php artisan queue:work --sleep=3 --tries=3 --max-time=3600

# ── File Storage (S3 / Cloudflare R2) ─────────────────────────
# Switch from ephemeral local disk to object storage so uploads survive redeploys.
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=YOUR_S3_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_S3_SECRET
AWS_DEFAULT_REGION=auto
AWS_BUCKET=YOUR_BUCKET_NAME
# Cloudflare R2 only — uncomment these two:
# AWS_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true

# ── CORS / Sanctum ────────────────────────────────────────────
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN.railway.app
SANCTUM_STATEFUL_DOMAINS=YOUR_FRONTEND_DOMAIN.railway.app,YOUR_BACKEND_DOMAIN.railway.app

# ── Mail ──────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ── SMS Gateway ───────────────────────────────────────────────
SMS_API_PH_KEY=

# ── Optional: Redis (better performance than DB driver) ───────
# Provision a Redis plugin in Railway, then switch drivers:
# REDIS_URL=${REDIS_URL}
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
