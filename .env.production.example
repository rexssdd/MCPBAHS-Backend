# ============================================================
# Production Environment Variables for Railway Deployment
# ============================================================
# Copy this file to .env on your local machine ONLY for reference.
# Set all actual values in the Railway dashboard → Variables tab.
# NEVER commit real secrets to Git.

APP_NAME=HighSchoolManagementSystem
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_OUTPUT_OF_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://YOUR_BACKEND_DOMAIN.railway.app

# ── Database ─────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically for linked PostgreSQL.
# Use DB_URL so Laravel parses it directly (no need to set individual vars).
DB_CONNECTION=pgsql
DB_URL=${DATABASE_URL}

# ── Logging ──────────────────────────────────────────────────
# stderr routes logs to Railway's log aggregator
LOG_CHANNEL=stderr
LOG_LEVEL=info

# ── Session & Cache ──────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
CACHE_STORE=database

# ── Queue ────────────────────────────────────────────────────
# Uses the database driver. For a dedicated worker, add a second
# Railway service running: php artisan queue:work --sleep=3 --tries=3
QUEUE_CONNECTION=database

# ── File Storage (S3 / Cloudflare R2) ────────────────────────
# Switch from ephemeral local disk to object storage so uploaded
# report files survive redeploys and restarts.
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=YOUR_S3_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_S3_SECRET
AWS_DEFAULT_REGION=auto
AWS_BUCKET=YOUR_BUCKET_NAME
# For Cloudflare R2, set endpoint below and USE_PATH_STYLE to true:
# AWS_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true

# ── CORS / Sanctum ───────────────────────────────────────────
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN.railway.app
SANCTUM_STATEFUL_DOMAINS=YOUR_FRONTEND_DOMAIN.railway.app,YOUR_BACKEND_DOMAIN.railway.app

# ── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ── SMS Gateway ──────────────────────────────────────────────
SMS_API_PH_KEY=

# ── Optional: Redis (better performance than DB driver) ──────
# Provision a Redis plugin in Railway, then uncomment:
# REDIS_URL=${REDIS_URL}
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
