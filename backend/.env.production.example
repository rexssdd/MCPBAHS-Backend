# Production Environment Variables - Copy and update for deployment
# DO NOT commit actual secrets to Git - use Railway dashboard

APP_NAME=HighSchoolManagementSystem
APP_ENV=production
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxx  # Generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://YOUR_RAILWAY_DOMAIN.railway.app

# Database - Railway provides these via DATABASE_URL
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=railway
DB_USERNAME=postgres
DB_PASSWORD=

# Logging - Use stdout for Railway log aggregation
LOG_CHANNEL=stack
LOG_LEVEL=info

# Session & Cache - Use database or Redis
SESSION_DRIVER=database
SESSION_ENCRYPT=true
CACHE_STORE=database

# Queue - Database based for simplicity, or use Redis
QUEUE_CONNECTION=database

# Frontend CORS - Update with your actual frontend domain
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN.railway.app
SANCTUM_STATEFUL_DOMAINS=YOUR_FRONTEND_DOMAIN.railway.app,YOUR_BACKEND_DOMAIN.railway.app

# Mail - Configure for production
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# SMS Gateway (if used)
SMS_API_PH_KEY=

# Optional: Redis for better performance
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
