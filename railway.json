{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "sh /app/start.sh",
    "healthcheckPath": "/up",
    "healthcheckTimeout": 120,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  }
}
